# Path to your Obsidian vault
VAULT_PATH=/Users/yourname/Documents/your-vault

# OpenSearch connection (defaults match docker-compose.yml)
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=obsidian-notes

# Embedding model (must match the model used to generate cached embeddings)
EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_BATCH_SIZE=32

# HNSW parameters
HNSW_M=16
HNSW_EF_CONSTRUCTION=100
HNSW_EF_SEARCH=100
